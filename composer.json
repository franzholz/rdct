{
	"name": "friendsoftypo3/rdct",
	"type": "typo3-cms-extension",
	"description": "RDCT Frontend redirects - Frontend redirects based on RDCT GET parameter",
	"homepage": "https://extensions.typo3.org/extension/rdct",
	"support": {
		"docs": "https://docs.typo3.org/p/friendsoftypo3/rdct/main/en-us/",
		"issues": "https://github.com/FriendsOfTYPO3/rdct/issues",
		"source": "https://github.com/FriendsOfTYPO3/rdct"
	},
	"license": ["GPL-2.0-or-later"],
	"authors": [
		{
			"name": "Benni Mack",
			"email": "benni@typo3.org",
			"role": "Developer"
		}
	],
	"require": {
		"typo3/cms-core": ">=13.4.0 <=14.3.99",
		"typo3/cms-frontend": ">=13.4.0 <=14.3.99"
	},
	"replace": {
		"typo3-ter/rdct": "*"
	},
	"extra": {
		"typo3/cms": {
			"extension-key": "rdct",
			"version": "3.2.0",
			"Package": {
				"providesPackages": {}
			}
		}
	},
	"autoload": {
		"psr-4": {
			"FoT3\\Rdct\\": "Classes/"
		}
	}
}
